{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "general": {
    "vimMode": false,
    "enableNotifications": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "maxCount": 100
    }
  },
  "ide": {
    "enabled": true,
    "hasSeenNudge": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "hideBanner": true,
    "showLineNumbers": false,
    "theme": "ANSI",
    "footer": {
      "hideSandboxStatus": true,
      "hideCWD": false
    }
  }
}